{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dante",
  "version": "0.1.1",
  "identifier": "dev.dante.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Dante",
        "width": 1100,
        "height": 720,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Paste a curl. Get a runnable request.",
    "longDescription": "Local-first HTTP client for developers. Paste curl, hit Run, save to disk."
  }
}
